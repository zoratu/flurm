[
    %% FLURM Controller Configuration
    %% Copy this to your deployment directory and fill in actual values
    {flurm_controller, [
        {listen_port, 6817},
        {node_listen_port, 6819},
        {listen_address, "0.0.0.0"},
        {cluster_name, flurm},
        {cluster_nodes, []},
        {ra_data_dir, "/var/lib/flurm/ra"},
        {leader_check_interval, 1000},
        {forward_timeout, 5000},
        {election_timeout, 5000},

        %% Cloud Scaling - configure in deployment
        {cloud_scaling_enabled, false},
        {cloud_scaling_provider, aws},
        {cloud_scaling_config, #{
            region => <<"us-west-2">>,
            access_key_id => <<"YOUR_ACCESS_KEY">>,
            secret_access_key => <<"YOUR_SECRET_KEY">>,
            ami_id => <<"ami-xxxxxxxxx">>,
            subnet_id => <<"subnet-xxxxxxxx">>,
            security_groups => [<<"sg-xxxxxxxx">>],
            key_name => <<"your-key-name">>,
            spot_max_price => <<"0.10">>,
            user_data => <<"">>
        }},
        {cloud_scaling_policy, #{
            min_nodes => 0,
            max_nodes => 10,
            scale_up_increment => 1,
            cooldown_seconds => 60,
            spot_enabled => true
        }}
    ]},

    %% FLURM Node Daemon Configuration
    {flurm_node_daemon, [
        {controller_host, "localhost"},
        {controller_port, 6819},
        {heartbeat_interval, 30000},
        {state_file, "/var/lib/flurm/node_state.dat"}
    ]},

    %% FLURM Database Configuration
    {flurm_db, [
        {data_dir, "/var/lib/flurm/db"},
        {cluster_name, flurm_cluster}
    ]},

    %% Ra Configuration (Raft consensus)
    {ra, [
        {data_dir, "/var/lib/flurm/ra"}
    ]},

    %% Lager Logging Configuration
    {lager, [
        {handlers, [
            {lager_console_backend, [{level, info}]},
            {lager_file_backend, [
                {file, "/var/log/flurm/error.log"},
                {level, error}
            ]},
            {lager_file_backend, [
                {file, "/var/log/flurm/console.log"},
                {level, info}
            ]}
        ]},
        {error_logger_redirect, true},
        {crash_log, "/var/log/flurm/crash.log"}
    ]},

    {sasl, [{sasl_error_logger, false}]},
    {kernel, [{logger_level, info}]}
].
